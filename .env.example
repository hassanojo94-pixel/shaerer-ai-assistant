# Environment Configuration Template for SHAERER AI Assistant

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=SHAERER
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# Secret Keys
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=sqlite:///./shaerer.db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
JWT_COOKIE_NAME=access_token
JWT_COOKIE_SECURE=False
JWT_COOKIE_HTTPONLY=True
JWT_COOKIE_SAMESITE=lax

# ============================================================================
# SECURITY
# ============================================================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL=True

RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_API_KEY=your-llm-api-key-here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# ============================================================================
# VOICE CONFIGURATION
# ============================================================================
VOICE_STT_PROVIDER=google
VOICE_STT_API_KEY=your-stt-api-key-here
VOICE_STT_LANGUAGE=en-US

VOICE_TTS_PROVIDER=google
VOICE_TTS_API_KEY=your-tts-api-key-here
VOICE_TTS_LANGUAGE=en-US
VOICE_TTS_VOICE=en-US-Neural2-C

VOICE_WAKE_WORD=hey shaerer
VOICE_WAKE_WORD_SENSITIVITY=0.5

VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1
VOICE_CHUNK_SIZE=1024

# ============================================================================
# IMAGE PROCESSING
# ============================================================================
IMAGE_PROVIDER=openai
IMAGE_API_KEY=your-image-api-key-here
IMAGE_MODEL=gpt-4-vision-preview
IMAGE_MAX_SIZE=5242880
IMAGE_ALLOWED_FORMATS=jpg,jpeg,png,gif,webp

# ============================================================================
# FILE MANAGEMENT
# ============================================================================
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=52428800
FILE_ALLOWED_EXTENSIONS=txt,pdf,doc,docx,xls,xlsx,csv,json,py,js,html,css
FILE_CHUNK_SIZE=1048576

# ============================================================================
# MEMORY CONFIGURATION
# ============================================================================
MEMORY_VECTOR_PROVIDER=openai
MEMORY_VECTOR_MODEL=text-embedding-3-small
MEMORY_VECTOR_API_KEY=
MEMORY_MAX_CONTEXT=10000
MEMORY_MIN_IMPORTANCE=0.3
MEMORY_RETENTION_DAYS=365
MEMORY_EMBEDDING_BATCH_SIZE=100

# ============================================================================
# EMAIL SERVICE
# ============================================================================
EMAIL_PROVIDER=gmail
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ============================================================================
# CALENDAR INTEGRATION
# ============================================================================
CALENDAR_PROVIDER=google
CALENDAR_API_KEY=your-calendar-api-key

# ============================================================================
# WEATHER & NEWS
# ============================================================================
WEATHER_PROVIDER=openweathermap
WEATHER_API_KEY=your-weather-api-key

NEWS_PROVIDER=newsapi
NEWS_API_KEY=your-news-api-key

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/shaerer.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

SENTRY_ENABLED=False
SENTRY_DSN=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_VOICE_ENABLED=True
FEATURE_CODE_EXECUTION_ENABLED=True
FEATURE_BROWSER_AUTOMATION_ENABLED=True
FEATURE_EMAIL_ENABLED=True
FEATURE_CALENDAR_ENABLED=True
FEATURE_PLUGINS_ENABLED=True
FEATURE_FILE_UPLOAD_ENABLED=True
FEATURE_IMAGE_ANALYSIS_ENABLED=True

# ============================================================================
# PERFORMANCE
# ============================================================================
CACHE_BACKEND=memory
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379

TASK_QUEUE_ENABLED=True
TASK_QUEUE_BACKEND=memory

# ============================================================================
# DEPLOYMENT
# ============================================================================
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
FRONTEND_BASE_URL=http://localhost:3000
